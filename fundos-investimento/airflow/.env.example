# ─── Airflow ───────────────────────────────────────────────
AIRFLOW_UID=50000

# ─── Databricks Community Edition ──────────────────────────
# Host sem https:// e sem barra final
# Exemplo: community.cloud.databricks.com
DATABRICKS_HOST=community.cloud.databricks.com

# Token de acesso pessoal
# Gerar em: User Settings > Access Tokens > Generate New Token
DATABRICKS_TOKEN=dapi_SEU_TOKEN_AQUI

# HTTP Path do cluster (aba JDBC/ODBC na configuração do cluster)
# Formato Community Edition: /sql/protocolv1/o/<workspace_id>/<cluster_id>
DATABRICKS_HTTP_PATH=/sql/protocolv1/o/WORKSPACE_ID/CLUSTER_ID

# ID do cluster (para start/stop via API)
# Encontrado na URL do cluster: /#setting/clusters/<CLUSTER_ID>/configuration
DATABRICKS_CLUSTER_ID=SEU_CLUSTER_ID

# ─── dbt ───────────────────────────────────────────────────
DBT_PROFILES_DIR=/opt/dbt
